# ===== LLM =====
# 至少配一个；通过 LLM_MODEL 决定用哪个
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=anthropic:claude-sonnet-4-6

# ===== 数据源 =====
TUSHARE_TOKEN=
AKSHARE_RATE_LIMIT=10

# ===== 数据库 =====
# 本地 Postgres
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/valueinvesting
REDIS_URL=redis://localhost:6379/0
DUCKDB_PATH=./data/analytics.duckdb

# ===== 应用 =====
LOG_LEVEL=INFO
ENV=development
# JSON 数组格式（pydantic-settings 约定）
CORS_ORIGINS=["http://localhost:8420"]
