{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Install (uv sync)",
      "type": "shell",
      "command": "uv sync",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "Backend: Dev (uvicorn)",
      "type": "shell",
      "command": "uv run uvicorn app.main:app --reload --port 8421",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Backend: Test (pytest)",
      "type": "shell",
      "command": "uv run pytest -v",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Backend: Lint (ruff)",
      "type": "shell",
      "command": "uv run ruff check .",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Install (npm)",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Dev (next)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Typecheck",
      "type": "shell",
      "command": "npm run typecheck",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "All: Dev (backend + frontend)",
      "dependsOn": ["Backend: Dev (uvicorn)", "Frontend: Dev (next)"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
